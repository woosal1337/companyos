# ── Secrets (REQUIRED for any real deployment — generate fresh) ───────────────
# Encrypts stored integration/SSO secrets. A 32-byte urlsafe-base64 key:
#   python3 -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# If you leave this empty, a public dev key is used (fine for local eval ONLY).
COMPANYOS_KEK=
# A long random string. Generate:  openssl rand -hex 32
JWT_SECRET_KEY=

# ── Mode ──────────────────────────────────────────────────────────────────────
# development = http-friendly (non-secure cookies) for local evaluation.
# production  = secure cookies (serve over HTTPS) AND enforces strong secrets above.
ENV=development

# ── Origins (the browser-facing web URL) ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=companyos
POSTGRES_PASSWORD=companyos
POSTGRES_DB=companyos

# ── Host port overrides (optional) ────────────────────────────────────────────
# API_PORT=8000
# WEB_PORT=3000

# ── Live co-editing relay (optional; falls back to plain save when unset) ─────
# NEXT_PUBLIC_REALTIME_URL=

# ── Web → API origin (compose-internal default; baked into the web image at
#    build time — change only if not running web via this compose) ────────────
# BACKEND_ORIGIN=http://api:8000
