# Origin of the CompanyOS API the web app talks to (server-side proxy + SSR).
BACKEND_ORIGIN=http://localhost:8000

# Public WebSocket URL of the realtime co-editing relay (optional; collab editing
# falls back to plain save when unset).
NEXT_PUBLIC_REALTIME_URL=

# Public origins used to build absolute links when exporting docs as Markdown
# (llms.txt and "copy as Markdown"). Default to the local app when unset.
NEXT_PUBLIC_APP_ORIGIN=
NEXT_PUBLIC_DOCS_ORIGIN=
NEXT_PUBLIC_MCP_ORIGIN=

# Optional: serve docs on a separate subdomain. When both are set, requests to
# <APP_HOST>/docs redirect to <DOCS_HOST>. Leave unset to serve docs in-app.
APP_HOST=
DOCS_HOST=
