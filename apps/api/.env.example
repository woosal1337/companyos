# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://companyos:companyos@localhost:5434/companyos
# 32-byte urlsafe-base64 key-encryption key. Generate one with:
#   python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
COMPANYOS_KEK=
# A long random string. Must be a strong, non-default value when ENV=production.
JWT_SECRET_KEY=change-me-to-a-long-random-string
ENV=development
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins (must not be a wildcard in production).
CORS_ORIGINS=http://localhost:3000
# Public base URL of the web app (used to build invite accept links).
APP_BASE_URL=http://localhost:3000

# ─── Auth / tokens ───────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Comma-separated emails granted instance-admin rights.
INSTANCE_ADMIN_EMAILS=

# ─── MCP (agent gateway) ─────────────────────────────────────────────────────
OAUTH_ISSUER=http://localhost:8000
MCP_RESOURCE_BASE=https://mcp.example.com
MCP_ACCESS_TOKEN_EXPIRE_MINUTES=10
MCP_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI providers ────────────────────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-8
AI_TIMEOUT_SECONDS=60
AI_MAX_CONTEXT_CHARS=60000
AI_MAX_OUTPUT_TOKENS=2048
NOTIFY_TIMEOUT_SECONDS=10

# ─── OAuth integrations (optional) ───────────────────────────────────────────
SLACK_BASE_URL=https://slack.com/api
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
SLACK_SIGNING_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# When RESEND_API_KEY is empty, emails are logged instead of sent.
RESEND_API_KEY=
EMAIL_FROM=CompanyOS <noreply@example.com>
VERIFICATION_CODE_TTL_MINUTES=15

# ─── Object storage (S3-compatible / Cloudflare R2) ──────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=companyos-media
R2_ENDPOINT_URL=

# ─── Push notifications (Expo) ───────────────────────────────────────────────
PUSH_ENABLED=false
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# ─── Ops CLI (scripts/ops only; not read by the API server) ──────────────────
# COMPANYOS_TOKEN=cos_pat_...
